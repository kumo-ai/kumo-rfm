    "for _, row in ring_txns.iterrows():\n",
    "    if G.has_edge(row[\"user_id\"], row[\"merchant_id\"]):\n",
    "        G[row[\"user_id\"]][row[\"merchant_id\"]][\"weight\"] += 1\n",
    "    else:\n",
    "        G.add_edge(row[\"user_id\"], row[\"merchant_id\"], weight=1)\n",
    "\n",
    "fig, ax = plt.subplots(1, 1, figsize=(8, 6))\n",
